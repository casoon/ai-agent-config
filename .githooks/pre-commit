#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

python3 "$ROOT/scripts/render-codex-agents.py"

if ! git diff --quiet -- codex-agents/; then
  git add codex-agents/
  echo "pre-commit: regenerated codex-agents/ and staged changes"
fi

if ! command -v nosecrets >/dev/null 2>&1; then
  echo "pre-commit: warning — nosecrets not found on PATH, skipping secret scan" >&2
else
  nosecrets scan --staged
fi
